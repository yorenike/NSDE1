{
    "problem": {
        "domain_type": "square_with_hole",
        "hole_center_x": 0.5,
        "hole_center_y": 0.5,
        "hole_radius": 0.25
    },
    
    "grid": {
        "n": 32
    },
    
    "boundary": {
        "left": {
            "type": "dirichlet",
            "value": "from_test_function"
        },
        "right": {
            "type": "neumann",
            "value": "from_test_function"
        },
        "bottom": {
            "type": "neumann",
            "value": "from_test_function"
        },
        "top": {
            "type": "dirichlet",
            "value": "from_test_function"
        },
        "hole": {
            "type": "neumann",
            "value": "from_test_function"
        }
    },
    
    "test_function": {
        "name": "exp_y_sin_x"
    },
    
    "output": {
        "verbose": false,
        "save_solution": false,
        "output_dir": "./results"
    }
}